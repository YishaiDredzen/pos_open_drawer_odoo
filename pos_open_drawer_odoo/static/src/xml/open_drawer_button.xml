<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- COMPONENT TEMPLATE -->
    <t t-name="pos_open_drawer.OpenDrawerButton">
        <div class="drawer-btn-container">

            <button class="open-drawer-btn"
                    t-on-click="openDrawer">

                Open Drawer

            </button>

        </div>
    </t>

    <!-- INJECT COMPONENT INTO ORDER PANEL -->
    <t t-name="pos_open_drawer.OrderWidgetExtension"
       t-inherit="point_of_sale.OrderWidget"
       t-inherit-mode="extension">

        <!-- place directly under scanned products -->
        <xpath expr="//div[hasclass('orderlines')]" position="after">

            <OpenDrawerButton/>

        </xpath>

    </t>

</templates>