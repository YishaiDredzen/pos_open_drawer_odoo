<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="pos_open_drawer.OpenDrawerButton" owl="1">
        <button class="open-drawer-btn btn" t-on-click="openDrawer">
            <i class="fa fa-lock me-2"/>
            Open Register
        </button>
    </t>

    <t t-name="point_of_sale.ProductScreen" owl="1"
       t-inherit="point_of_sale.ProductScreen"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-screen')]" position="inside">
            <OpenDrawerButton />
        </xpath>
    </t>

</templates>
